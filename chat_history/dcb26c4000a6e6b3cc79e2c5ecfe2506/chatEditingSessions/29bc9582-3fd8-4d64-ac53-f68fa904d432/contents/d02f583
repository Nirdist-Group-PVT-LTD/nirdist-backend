version: '3.8'

services:
  mysql:
    image: mysql:8.0
    container_name: nirdist_mysql
    environment:
      MYSQL_ROOT_PASSWORD: password
      MYSQL_DATABASE: nirdist
      MYSQL_USER: nirdist_user
      MYSQL_PASSWORD: nirdist_password
    ports:
      - "3306:3306"
    volumes:
      - mysql_data:/var/lib/mysql
      - ./init.sql:/docker-entrypoint-initdb.d/init.sql
    networks:
      - nirdist_network

  springboot:
    image: maven:3.8.1-openjdk-17
    container_name: nirdist_backend
    working_dir: /app
    volumes:
      - .:/app
    ports:
      - "8080:8080"
    command: mvn spring-boot:run
    depends_on:
      - mysql
    environment:
      SPRING_DATASOURCE_URL: jdbc:mysql://mysql:3306/nirdist
      SPRING_DATASOURCE_USERNAME: root
      SPRING_DATASOURCE_PASSWORD: password
    networks:
      - nirdist_network

volumes:
  mysql_data:

networks:
  nirdist_network:
